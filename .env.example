# Сансар гар утас худалдаа — орчны хувьсагч
# Энэ файлыг хуулж ".env.local" нэртэй болгоод утгуудыг бөглөнө үү.
# Утгуудыг: Supabase Dashboard → Project Settings → API хэсгээс олно.
#
# .env.local нь git-д орохгүй (нууц). .env.example-г л commit хийнэ.

# --- Олон нийтэд ил (browser-т ачаалагдана) ---
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOi...   # "anon" / "publishable" key

# --- ЗӨВХӨН сервер тал (НУУЦ — хэзээ ч NEXT_PUBLIC болгож болохгүй) ---
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOi...        # "service_role" / "secret" key
